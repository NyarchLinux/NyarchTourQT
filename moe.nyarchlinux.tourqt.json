{
  "id": "moe.nyarchlinux.tourqt",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.8",
  "sdk": "org.kde.Sdk",
  "base": "io.qt.PySide.BaseApp",
  "base-version": "6.8",
  "command": "nyarchtourqt",
  "finish-args": [
    "--share=ipc",
    "--share=network",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--talk-name=org.freedesktop.Flatpak"
  ],
  "cleanup-commands": [
    "/app/cleanup-BaseApp.sh"
  ],
  "modules": [
    {
      "name": "nyarchtourqt",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --no-build-isolation --prefix=/app ."
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
